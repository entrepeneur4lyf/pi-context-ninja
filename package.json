{
  "name": "pi-context-ninja",
  "version": "0.1.0",
  "type": "module",
  "description": "Silent-first context optimization extension for Pi",
  "keywords": [
    "pi-package"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm test"
  },
  "engines": {
    "node": ">=20.6.0"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "0.67.2",
    "@mariozechner/pi-ai": "0.67.2",
    "@mariozechner/pi-coding-agent": "0.67.2",
    "better-sqlite3": "^11.0.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.0"
  }
}
